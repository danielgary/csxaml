<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="LocalNuGetCache" value="%USERPROFILE%\.nuget\packages" />
    <add key="VisualStudioOfflinePackages" value="C:\Program Files (x86)\Microsoft SDKs\NuGetPackages\" />
    <add key="NuGet.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
