{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-demo-x64",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}\\Csxaml.Demo\\Csxaml.Demo.csproj",
        "-p:Platform=x64",
        "-nr:false",
        "-p:UseSharedCompilation=false"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
