{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-demo",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}\\Csxaml.Demo\\Csxaml.Demo.csproj",
        "-nr:false",
        "-p:UseSharedCompilation=false"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build-starter",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}\\samples\\Csxaml.Starter\\Csxaml.Starter.csproj",
        "-nr:false",
        "-p:UseSharedCompilation=false"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "run-benchmarks",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "-c",
        "Release",
        "--project",
        "${workspaceFolder}\\Csxaml.Benchmarks\\Csxaml.Benchmarks.csproj",
        "--",
        "--filter",
        "*",
        "--job",
        "short"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": "test"
    },
    {
      "label": "run-benchmarks-generator",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "-c",
        "Release",
        "--project",
        "${workspaceFolder}\\Csxaml.Benchmarks\\Csxaml.Benchmarks.csproj",
        "--",
        "--filter",
        "*Generator*",
        "--job",
        "short"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": "test"
    },
    {
      "label": "run-benchmarks-metadata",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "-c",
        "Release",
        "--project",
        "${workspaceFolder}\\Csxaml.Benchmarks\\Csxaml.Benchmarks.csproj",
        "--",
        "--filter",
        "*Metadata*",
        "--job",
        "short"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": "test"
    },
    {
      "label": "run-benchmarks-runtime",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "-c",
        "Release",
        "--project",
        "${workspaceFolder}\\Csxaml.Benchmarks\\Csxaml.Benchmarks.csproj",
        "--",
        "--filter",
        "*Runtime*",
        "--job",
        "short"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": "test"
    },
    {
      "label": "run-benchmarks-tooling",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "-c",
        "Release",
        "--project",
        "${workspaceFolder}\\Csxaml.Benchmarks\\Csxaml.Benchmarks.csproj",
        "--",
        "--filter",
        "*Tooling*",
        "--job",
        "short"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": "test"
    },
    {
      "label": "build-csxaml-vsix",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}\\Csxaml.VisualStudio\\Csxaml.VisualStudio.csproj",
        "-c",
        "Debug",
        "-m:1",
        "-nr:false",
        "-p:UseSharedCompilation=false"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOTNET_CLI_HOME": "${workspaceFolder}\\.dotnet-home",
          "NUGET_PACKAGES": "${workspaceFolder}\\.dotnet-home\\.nuget\\packages"
        }
      },
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "build-csxaml-language-server",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}\\Csxaml.LanguageServer\\Csxaml.LanguageServer.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "launch-visual-studio-exp-csxaml",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\Run-CsxamlVisualStudioBootstrap.ps1",
        "-Configuration",
        "Debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
