{
  "name": "csxaml-vscode-extension",
  "displayName": "CSXAML",
  "description": "Syntax highlighting, snippets, and shared language-server support for CSXAML.",
  "version": "0.0.1",
  "publisher": "danielgarysoftware",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/danielgary/csxaml.git"
  },
  "homepage": "https://github.com/danielgary/csxaml",
  "bugs": {
    "url": "https://github.com/danielgary/csxaml/issues"
  },
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node ./scripts/bundle-extension.mjs",
    "bundle": "npm run build",
    "test": "npm run bundle && node --test",
    "vscode:prepublish": "npm run build",
    "package": "vsce package",
    "package:pre-release": "vsce package --pre-release",
    "package:vsix": "npm run bundle && vsce package --allow-missing-repository"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "workspaceContains:**/*.csxaml",
    "onLanguage:csxaml",
    "onCommand:csxaml.restartLanguageServer"
  ],
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "csxaml",
    "winui",
    "xaml",
    "csharp"
  ],
  "contributes": {
    "commands": [
      {
        "command": "csxaml.restartLanguageServer",
        "title": "CSXAML: Restart Language Server"
      }
    ],
    "configuration": {
      "title": "CSXAML",
      "properties": {
        "csxaml.languageServer.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional path to `Csxaml.LanguageServer.exe` or `Csxaml.LanguageServer.dll`. Relative paths resolve from the first workspace folder when available, otherwise from the extension folder."
        }
      }
    },
    "languages": [
      {
        "id": "csxaml",
        "aliases": [
          "CSXAML",
          "csxaml"
        ],
        "extensions": [
          ".csxaml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "csxaml",
        "path": "./snippets/csxaml.code-snippets"
      }
    ],
    "grammars": [
      {
        "language": "csxaml",
        "scopeName": "source.csxaml",
        "path": "./syntaxes/csxaml.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.expression.csxaml": "csharp",
          "meta.embedded.header.csxaml": "csharp",
          "meta.embedded.inject.csxaml": "csharp",
          "meta.embedded.parameters.csxaml": "csharp",
          "meta.embedded.state.csxaml": "csharp"
        }
      },
      {
        "scopeName": "source.csxaml.embedded.csharp",
        "path": "./syntaxes/csxaml-embedded-csharp.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.expression.csxaml": "csharp"
        }
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0"
  }
}
