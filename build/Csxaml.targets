<Project>
  <PropertyGroup Condition="'$(EnableCsxaml)' == 'true'">
    <CsxamlIntermediateRoot Condition="'$(CsxamlIntermediateRoot)' == ''">$(IntermediateOutputPath)Csxaml</CsxamlIntermediateRoot>
    <CsxamlGeneratedDirectory Condition="'$(CsxamlGeneratedDirectory)' == ''">$(CsxamlIntermediateRoot)\Generated</CsxamlGeneratedDirectory>
    <CsxamlSourceManifestFile Condition="'$(CsxamlSourceManifestFile)' == ''">$(CsxamlIntermediateRoot)\Sources.txt</CsxamlSourceManifestFile>
    <CsxamlReferenceManifestFile Condition="'$(CsxamlReferenceManifestFile)' == ''">$(CsxamlIntermediateRoot)\References.txt</CsxamlReferenceManifestFile>
    <CsxamlProjectContextFile Condition="'$(CsxamlProjectContextFile)' == ''">$(CsxamlIntermediateRoot)\ProjectContext.txt</CsxamlProjectContextFile>
    <CsxamlStampFile Condition="'$(CsxamlStampFile)' == ''">$(CsxamlIntermediateRoot)\Generation.stamp</CsxamlStampFile>
    <CsxamlDefaultNamespace Condition="'$(CsxamlDefaultNamespace)' == '' and '$(RootNamespace)' != ''">$(RootNamespace)</CsxamlDefaultNamespace>
    <CsxamlDefaultNamespace Condition="'$(CsxamlDefaultNamespace)' == ''">$(AssemblyName)</CsxamlDefaultNamespace>
    <CsxamlInternalGeneratedNamespace Condition="'$(CsxamlInternalGeneratedNamespace)' == ''">$(CsxamlDefaultNamespace).__CsxamlGenerated</CsxamlInternalGeneratedNamespace>
    <CsxamlGeneratorCommand Condition="'$(CsxamlGeneratorCommand)' == '' and '$(CsxamlGeneratorProject)' != ''">dotnet run --project &quot;$(CsxamlGeneratorProject)&quot; --</CsxamlGeneratorCommand>
    <CsxamlGeneratorCommand Condition="'$(CsxamlGeneratorCommand)' == '' and '$(CsxamlGeneratorAssembly)' != ''">dotnet exec &quot;$(CsxamlGeneratorAssembly)&quot;</CsxamlGeneratorCommand>
  </PropertyGroup>

  <ItemGroup Condition="'$(EnableCsxaml)' == 'true'">
    <CsxamlSource
      Include="**\*.csxaml"
      Exclude="$(DefaultItemExcludes);bin\**;obj\**"
      Condition="'$(CsxamlEnableDefaultSourceGlob)' == 'true'" />
    <CsxamlGeneratorInput Include="$(CsxamlGeneratorProject)" Condition="'$(CsxamlGeneratorProject)' != ''" />
    <CsxamlGeneratorInput Include="$(CsxamlGeneratorAssembly)" Condition="'$(CsxamlGeneratorProject)' == '' and '$(CsxamlGeneratorAssembly)' != ''" />
    <CsxamlGeneratorInput
      Include="$(MSBuildThisFileDirectory)..\Csxaml.Generator\**\*.cs"
      Condition="Exists('$(MSBuildThisFileDirectory)..\Csxaml.Generator')"
      Exclude="$(MSBuildThisFileDirectory)..\Csxaml.Generator\bin\**;$(MSBuildThisFileDirectory)..\Csxaml.Generator\obj\**" />
  </ItemGroup>

  <Target
    Name="ValidateCsxamlGenerator"
    Condition="'$(EnableCsxaml)' == 'true' and '@(CsxamlSource)' != ''">
    <Error
      Condition="'$(CsxamlGeneratorCommand)' == ''"
      Text="CSXAML generation is enabled, but no generator command could be resolved. Set CsxamlGeneratorProject, CsxamlGeneratorAssembly, or reference the Csxaml.Generator package." />
    <Error
      Condition="'$(CsxamlGeneratorProject)' != '' and !Exists('$(CsxamlGeneratorProject)')"
      Text="CSXAML generator project was not found: $(CsxamlGeneratorProject)" />
    <Error
      Condition="'$(CsxamlGeneratorProject)' == '' and '$(CsxamlGeneratorAssembly)' != '' and !Exists('$(CsxamlGeneratorAssembly)')"
      Text="CSXAML generator assembly was not found: $(CsxamlGeneratorAssembly)" />
  </Target>

  <Target
    Name="PrepareCsxamlInputs"
    DependsOnTargets="ValidateCsxamlGenerator;ResolveReferences"
    Condition="'$(EnableCsxaml)' == 'true' and '@(CsxamlSource)' != ''">
    <MakeDir Directories="$(CsxamlIntermediateRoot)" />
    <MakeDir Directories="$(CsxamlGeneratedDirectory)" />

    <ItemGroup>
      <CsxamlGeneratorReference Include="@(ReferencePath)" />
      <CsxamlGeneratorReference Include="@(ReferenceCopyLocalPaths)" />
    </ItemGroup>

    <WriteLinesToFile
      File="$(CsxamlSourceManifestFile)"
      Lines="@(CsxamlSource->'%(FullPath)')"
      Overwrite="true"
      WriteOnlyWhenDifferent="true" />
    <WriteLinesToFile
      File="$(CsxamlReferenceManifestFile)"
      Lines="@(CsxamlGeneratorReference)"
      Overwrite="true"
      WriteOnlyWhenDifferent="true" />
    <WriteLinesToFile
      File="$(CsxamlProjectContextFile)"
      Lines="$(AssemblyName);$(CsxamlDefaultNamespace);$(CsxamlInternalGeneratedNamespace)"
      Overwrite="true"
      WriteOnlyWhenDifferent="true" />
  </Target>

  <Target
    Name="GenerateCsxaml"
    DependsOnTargets="PrepareCsxamlInputs"
    BeforeTargets="MarkupCompilePass1;CoreCompile"
    Inputs="@(CsxamlSource);@(ReferencePath);@(ReferenceCopyLocalPaths);@(CsxamlGeneratorInput);$(CsxamlSourceManifestFile);$(CsxamlReferenceManifestFile);$(CsxamlProjectContextFile);$(MSBuildThisFileFullPath);$(MSBuildThisFileDirectory)Csxaml.props"
    Outputs="$(CsxamlStampFile)"
    Condition="'$(EnableCsxaml)' == 'true' and '@(CsxamlSource)' != ''">
    <Exec
      Command="$(CsxamlGeneratorCommand) --out &quot;$(CsxamlGeneratedDirectory)&quot; --assembly-name &quot;$(AssemblyName)&quot; --default-namespace &quot;$(CsxamlDefaultNamespace)&quot; --generated-namespace &quot;$(CsxamlInternalGeneratedNamespace)&quot; --references-file &quot;$(CsxamlReferenceManifestFile)&quot; @(CsxamlSource->'&quot;%(FullPath)&quot;', ' ')"
      WorkingDirectory="$(MSBuildProjectDirectory)" />
    <Touch Files="$(CsxamlStampFile)" AlwaysCreate="true" />
  </Target>

  <Target
    Name="IncludeCsxamlGeneratedCompileItems"
    DependsOnTargets="GenerateCsxaml"
    BeforeTargets="MarkupCompilePass1;CoreCompile"
    Condition="'$(EnableCsxaml)' == 'true' and '@(CsxamlSource)' != ''">
    <ItemGroup>
      <Compile Include="$(CsxamlGeneratedDirectory)\**\*.g.cs" Visible="false" />
      <FileWrites Include="$(CsxamlSourceManifestFile)" />
      <FileWrites Include="$(CsxamlReferenceManifestFile)" />
      <FileWrites Include="$(CsxamlProjectContextFile)" />
      <FileWrites Include="$(CsxamlStampFile)" />
      <FileWrites Include="$(CsxamlGeneratedDirectory)\**\*.g.cs" Condition="Exists('$(CsxamlGeneratedDirectory)')" />
      <FileWrites Include="$(CsxamlIntermediateRoot)\Maps\**\*.json" Condition="Exists('$(CsxamlIntermediateRoot)\Maps')" />
    </ItemGroup>
  </Target>

  <Target
    Name="CleanCsxamlOutputs"
    AfterTargets="CoreClean"
    Condition="'$(EnableCsxaml)' == 'true' and Exists('$(CsxamlIntermediateRoot)')">
    <RemoveDir Directories="$(CsxamlIntermediateRoot)" />
  </Target>
</Project>
