<Project>
  <PropertyGroup>
    <EnableCsxaml Condition="'$(EnableCsxaml)' == ''">false</EnableCsxaml>
    <CsxamlEnableDefaultSourceGlob Condition="'$(CsxamlEnableDefaultSourceGlob)' == ''">true</CsxamlEnableDefaultSourceGlob>
    <CsxamlGeneratorProjectCandidate>$(MSBuildThisFileDirectory)..\Csxaml.Generator\Csxaml.Generator.csproj</CsxamlGeneratorProjectCandidate>
    <CsxamlGeneratorProject Condition="'$(CsxamlGeneratorProject)' == '' and Exists('$(CsxamlGeneratorProjectCandidate)')">$(CsxamlGeneratorProjectCandidate)</CsxamlGeneratorProject>
    <CsxamlGeneratorAssembly Condition="'$(CsxamlGeneratorAssembly)' == '' and '$(CsxamlGeneratorProject)' == ''">$(MSBuildThisFileDirectory)..\tools\net10.0\any\Csxaml.Generator.dll</CsxamlGeneratorAssembly>
  </PropertyGroup>
</Project>
