<Window
    x:Class="Csxaml.Samples.WheelProbe.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    xmlns:external="using:Csxaml.ExternalControls"
    Title="WinUI Wheel Probe">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <StackPanel
            x:Name="Root"
            Margin="24"
            Spacing="12"
            Loaded="Root_Loaded"
            PointerWheelChanged="Root_PointerWheelChanged">
            <TextBlock
                Text="WinUI wheel probe"
                FontSize="22"
                FontWeight="SemiBold" />
            <Button
                x:Name="ResetButton"
                Content="Reset probe"
                Click="ResetButton_Click" />
            <TextBlock
                x:Name="RouteText"
                automation:AutomationProperties.AutomationId="WheelProbeRouteStatus"
                Text="Wheel route: waiting"
                TextWrapping="Wrap" />
            <TextBlock
                x:Name="NativeMessagesText"
                automation:AutomationProperties.AutomationId="WheelProbeNativeStatus"
                Text="Native wheel messages: waiting"
                TextWrapping="Wrap" />
            <TextBlock
                x:Name="BoundsText"
                automation:AutomationProperties.AutomationId="WheelProbeBoundsStatus"
                Text="Bounds: waiting"
                TextWrapping="Wrap" />
            <ListView
                x:Name="BareListView"
                automation:AutomationProperties.AutomationId="WheelProbeBareList"
                Height="140"
                ScrollViewer.HorizontalScrollMode="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                ScrollViewer.VerticalScrollMode="Enabled"
                PointerWheelChanged="BareListView_PointerWheelChanged" />
            <Border
                x:Name="BorderWrapper"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="8"
                PointerWheelChanged="BorderWrapper_PointerWheelChanged">
                <ListView
                    x:Name="BorderListView"
                    automation:AutomationProperties.AutomationId="WheelProbeBorderList"
                    Height="140"
                    ScrollViewer.HorizontalScrollMode="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollMode="Enabled"
                    PointerWheelChanged="BorderListView_PointerWheelChanged" />
            </Border>
            <external:FluentCard
                automation:AutomationProperties.AutomationId="WheelProbeFluentWrapper">
                <StackPanel
                    x:Name="FluentContent"
                    PointerWheelChanged="FluentContent_PointerWheelChanged">
                    <ListView
                        x:Name="FluentListView"
                        automation:AutomationProperties.AutomationId="WheelProbeFluentList"
                        Height="140"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollMode="Enabled"
                        PointerWheelChanged="FluentListView_PointerWheelChanged" />
                </StackPanel>
            </external:FluentCard>
        </StackPanel>
    </Grid>
</Window>
