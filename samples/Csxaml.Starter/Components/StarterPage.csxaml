using Microsoft.UI.Xaml;

namespace Csxaml.Starter;

component Element StarterPage {
    State<int> Count = new State<int>(0);
    State<string> Name = new State<string>("CSXAML");

    void IncrementCount()
    {
        Count.Value += 1;
    }

    void ClearName()
    {
        Name.Value = string.Empty;
    }

    var greetingName = string.IsNullOrWhiteSpace(Name.Value)
        ? "friend"
        : Name.Value.Trim();

    render <Border
        AutomationProperties.Name="CSXAML starter page"
        Padding={24}>
        <StackPanel Spacing={12}>
            <TextBlock Text="CSXAML Starter" FontSize={28} />
            <TextBlock Text="A minimal WinUI app rendered from CSXAML." />
            <GreetingCard Name={greetingName} Count={Count.Value} />
            <TextBox
                AutomationProperties.Name="Display name"
                Text={Name.Value}
                PlaceholderText="Name"
                OnTextChanged={value => Name.Value = value}
                Width={320} />
            <Button
                AutomationProperties.Name="Increment counter"
                Content="Increment counter"
                OnClick={() => IncrementCount()} />
            <Button
                AutomationProperties.Name="Clear display name"
                Content="Clear name"
                OnClick={() => ClearName()} />
        </StackPanel>
    </Border>;
}
